# Required in production. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=e98902b5946b9d9803d2cd8682c2aa3a9a1871149df92ee21ca2508e45b350e0
NEXTAUTH_URL=http://localhost:3000

# Vercel Cron authenticates the daily /api/cron/backups request with this value.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Secure by default. Set false only for local/demo environments without email delivery.
AUTH_REQUIRE_EMAIL_VERIFICATION=false

# OAuth providers (leave empty to hide the provider button locally)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Transactional email for account verification (Resend)
RESEND_API_KEY=
AUTH_EMAIL_FROM=

# Composite family trees rollout and resolver operational limits.
COMPOSITE_TREES_ENABLED=true
COMPOSITE_RESOLVER_CONCURRENCY=5
# MVP limits: 20 sources, 1,000 resolved members target, 3-second metadata target.
# Resolved cache is disposable and permission/audience scoped; source blobs remain authoritative.
