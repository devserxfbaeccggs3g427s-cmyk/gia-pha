# Required in production. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=e98902b5946b9d9803d2cd8682c2aa3a9a1871149df92ee21ca2508e45b350e0
NEXTAUTH_URL=http://192.168.2.23:3020

# Private Vercel Blob data store. `vercel env pull .env.local` normally provides
# BLOB_STORE_ID + VERCEL_OIDC_TOKEN. BLOB_READ_WRITE_TOKEN is the fallback.
BLOB_STORE_ID=
VERCEL_OIDC_TOKEN=
BLOB_READ_WRITE_TOKEN=

# Vercel Cron authenticates the daily /api/cron/backups request with this value.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Secure by default. Set false only for local/demo environments without email delivery.
AUTH_REQUIRE_EMAIL_VERIFICATION=true

# OAuth providers (leave empty to hide the provider button locally)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Transactional email for account verification (Resend)
RESEND_API_KEY=
AUTH_EMAIL_FROM=
